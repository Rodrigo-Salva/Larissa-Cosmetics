---
export interface Props {
  id: number;
  nombre: string;
  precio: number;
  descripcion: string;
  categoria: string;
  badge?: string;
  imagen: string;
  tags: string[];
}
const { id, nombre, precio, descripcion, categoria, imagen, tags } = Astro.props;
const pFmt = `S/ ${precio.toLocaleString("es-PE")}`;
---

<article
  class="product-card fade-in"
  data-id={id}
  data-categoria={categoria}
  data-nombre={nombre}
  data-descripcion={descripcion}
  data-precio={precio}
  role="button"
  tabindex="0"
  aria-label={`Ver ${nombre}`}
>
  <div class="card-img-wrap">
    <span class="card-cat-pill">{categoria}</span>
    <img
      src={imagen}
      alt={nombre}
      width="400"
      height="280"
      loading="lazy"
      decoding="async"
      class="card-img"
      onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
    />
    <div class="card-img-fallback" style="display:none" aria-hidden="true">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.4">
        <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
      </svg>
    </div>
  </div>

  <div class="card-body">
    <h3 class="card-title">{nombre}</h3>
    <p class="card-desc">{descripcion}</p>
  </div>

  <div class="card-footer">
    <span class="card-price">{pFmt}</span>
    <div class="card-actions">
      <button class="btn-icon" data-open={id} aria-label="Ver detalle">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
      </button>
      <button class="btn btn-accent btn-sm card-buy-btn" aria-label="Comprar">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span class="btn-label">Comprar</span>
      </button>
    </div>
  </div>
</article>

<style>
  .product-card {
    background: var(--color-surface);
    border-radius: 20px;
    border: 1px solid var(--color-border);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-sm);
    transition: transform 300ms cubic-bezier(.16,1,.3,1), box-shadow 300ms cubic-bezier(.16,1,.3,1);
    position: relative;
    cursor: pointer;
  }
  .product-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(122,52,148,.15);
  }
  .product-card:hover .card-img { transform: scale(1.06); }
  .product-card:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 3px; }

  .card-img-wrap {
    height: 210px;
    overflow: hidden;
    background: var(--color-surface-offset);
    position: relative;
  }
  .card-cat-pill {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    background: rgba(253,248,251,0.92);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: .04em;
    text-transform: uppercase;
    color: var(--color-tag-text);
    padding: 3px 10px;
    backdrop-filter: blur(8px);
  }
  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms cubic-bezier(0.16,1,0.3,1);
  }
  .card-img-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-surface-offset), var(--color-primary-light));
    color: var(--color-primary);
  }

  .card-body {
    padding: 14px 16px 8px;
    flex: 1;
  }
  .card-title {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    line-height: 1.25;
    margin-bottom: 5px;
    color: var(--color-text);
  }
  .card-desc {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px 14px;
    gap: 8px;
  }
  .card-price {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-primary);
  }
  .card-actions { display: flex; gap: 6px; align-items: center; }

  .btn-icon {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1.5px solid var(--color-border);
    background: var(--color-surface);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    transition: border-color var(--transition), color var(--transition), background var(--transition);
    cursor: pointer;
  }
  .btn-icon:hover { border-color: var(--color-primary); color: var(--color-primary); background: var(--color-primary-light); }

  .card-buy-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 7px 14px;
    font-size: 0.72rem;
    border-radius: 999px;
  }

  /* ── Mobile 2 columnas: layout compacto ── */
  @media (max-width: 768px) {
    .card-img-wrap { height: 155px; }
    .card-body { padding: 9px 11px 5px; }
    .card-title { font-size: 0.8rem; margin-bottom: 3px; }
    .card-desc { font-size: 0.67rem; -webkit-line-clamp: 2; }
    .card-footer { padding: 7px 11px 11px; }
    .btn-label { display: none; }
    .card-buy-btn { padding: 7px 10px; }
    .card-price { font-size: 0.85rem; }
  }

  @media (max-width: 420px) {
    .card-img-wrap { height: 140px; }
    .card-cat-pill { font-size: 0.55rem; padding: 2px 8px; }
  }
</style>
