<style>
/* ── CTA Section ── */
.cta-section { padding: var(--space-16) 0 var(--space-12); }
.cta-card {
  position: relative; overflow: hidden;
  background: linear-gradient(135deg, #3b0d6e 0%, #7a3494 50%, #b03086 100%);
  border-radius: 28px;
  padding: clamp(2.5rem, 6vw, 4.5rem) clamp(1.5rem, 5vw, 4rem);
  text-align: center;
  color: #fff;
}
.cta-deco {
  position: absolute; border-radius: 50%;
  background: rgba(255,255,255,.06); pointer-events: none;
}
.cta-deco-1 { width: 340px; height: 340px; top: -120px; right: -80px; }
.cta-deco-2 { width: 200px; height: 200px; bottom: -60px; left: -40px; }

.cta-inner { position: relative; z-index: 1; max-width: 520px; margin-inline: auto; }

.cta-icon {
  display: inline-flex; align-items: center; justify-content: center;
  width: 60px; height: 60px; border-radius: 50%;
  background: rgba(255,255,255,.15); backdrop-filter: blur(6px);
  color: #fff; margin-bottom: 20px;
}
.cta-card h2 {
  font-family: var(--font-display); font-size: var(--text-xl);
  font-weight: 700; margin-bottom: 12px; color: #fff; line-height: 1.2;
}
.cta-card h2 em { font-style: normal; color: #f9c8e8; }
.cta-card p { color: rgba(255,255,255,.75); margin-bottom: 28px; font-size: var(--text-sm); }

.cta-btn {
  display: inline-flex; align-items: center; gap: 10px;
  background: #fff; color: #1a7a40;
  font-size: 0.9rem; font-weight: 700;
  padding: 13px 28px; border-radius: 999px;
  box-shadow: 0 8px 24px rgba(0,0,0,.2);
  transition: transform var(--transition), box-shadow var(--transition);
}
.cta-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(0,0,0,.28); }

/* ── Footer ── */
footer {
  background: #100520;
  padding: 40px 0 0;
}
.footer-inner {
  display: flex; flex-direction: column; align-items: center;
  text-align: center;
}
.footer-brand { padding-bottom: 28px; }
.footer-logo-row {
  display: inline-flex; align-items: center; gap: 10px;
  margin-bottom: 12px;
}
.footer-logo {
  font-family: var(--font-display); font-size: 1.35rem;
  font-weight: 700; color: #fff; letter-spacing: -.01em;
}
.footer-tagline {
  font-size: 0.825rem; color: rgba(255,255,255,.45);
  line-height: 1.7;
}

.footer-divider {
  width: 100%; height: 1px;
  background: linear-gradient(to right, transparent, rgba(255,255,255,.1), transparent);
}

.footer-bottom {
  width: 100%;
  display: flex; align-items: center; justify-content: space-between;
  padding: 20px 0 24px;
  gap: 16px; flex-wrap: wrap;
}
.footer-links {
  display: flex; gap: 28px;
}
.footer-links a {
  font-size: 0.825rem; font-weight: 500;
  color: rgba(255,255,255,.45);
  transition: color var(--transition);
}
.footer-links a:hover { color: #d155a2; }
.footer-copy {
  font-size: 0.72rem; color: rgba(255,255,255,.25);
}

@media (max-width: 560px) {
  .footer-bottom { flex-direction: column; align-items: center; gap: 12px; padding: 18px 0 20px; }
  .cta-btn { width: 100%; justify-content: center; }
}
</style>
