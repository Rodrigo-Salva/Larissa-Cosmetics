---
export interface Props {
  totalProductos?: number;
}
const { totalProductos = 12 } = Astro.props;
---

<section class="hero">
  <div class="hero-bg">
    <img
      src="https://pplx-res.cloudinary.com/image/upload/pplx_search_images/fe0b493991ea9be1934ad3e2ad78be4282ee7a3d.jpg"
      alt="Colección skincare de lujo"
      width="1400"
      height="560"
      loading="eager"
      class="hero-bg-img"
    />
    <div class="hero-overlay"></div>
  </div>
  <div class="hero-content container">
    <h1 class="hero-title">Larissa</h1>
    <p class="hero-subtitle">
      Tu tienda de catálogo &amp; cosméticos · {totalProductos} productos
    </p>
  </div>
</section>

<div class="shop-bar container">
  <h2 class="shop-bar-title">Encuentra lo que necesitas</h2>
  <div class="shop-bar-search">
    <svg
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
    >
      <circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"></path>
    </svg>
    <input
      type="search"
      id="heroSearch"
      placeholder="Buscar en Larissa..."
      aria-label="Buscar"
    />
    <button class="btn btn-primary" id="heroBtn">Buscar</button>
  </div>
</div>

<style>
  .hero {
    position: relative;
    height: 300px;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
  }
  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(30, 10, 42, 0.75) 0%,
      rgba(122, 52, 148, 0.35) 55%,
      transparent 100%
    );
  }
  .hero-content {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: var(--space-8);
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(5rem, 14vw, 9rem);
    font-weight: 700;
    color: #fff;
    line-height: 0.9;
    opacity: 0.18;
    user-select: none;
  }
  .hero-subtitle {
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.8);
    margin-top: var(--space-2);
  }
  .shop-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    padding-block: var(--space-5);
    flex-wrap: wrap;
    border-bottom: 1px solid var(--color-divider);
  }
  .shop-bar-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
  }
  .shop-bar-search {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    background: var(--color-surface);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: var(--space-2) var(--space-2) var(--space-2) var(--space-5);
    box-shadow: var(--shadow-sm);
    flex: 1;
    max-width: 480px;
  }
  .shop-bar-search svg {
    color: var(--color-text-faint);
    flex-shrink: 0;
  }
  .shop-bar-search input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font-size: var(--text-sm);
    color: var(--color-text);
  }
  .shop-bar-search input::placeholder {
    color: var(--color-text-faint);
  }
  @media (max-width: 768px) {
    .hero {
      height: 220px;
    }
    .shop-bar {
      flex-direction: column;
      align-items: flex-start;
    }
    .shop-bar-search {
      max-width: 100%;
      width: 100%;
    }
  }
</style>

<script>
  function sync() {
    const q = (document.getElementById("heroSearch") as HTMLInputElement)
      ?.value;
    const si = document.getElementById("searchInput") as HTMLInputElement;
    if (si && q) {
      si.value = q;
      si.dispatchEvent(new Event("input"));
    }
    document.getElementById("catalogo")?.scrollIntoView({ behavior: "smooth" });
  }
  document.getElementById("heroSearch")?.addEventListener("keydown", (e) => {
    if (e.key === "Enter") sync();
  });
  document.getElementById("heroBtn")?.addEventListener("click", sync);
</script>
